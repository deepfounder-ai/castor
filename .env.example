# ── Castor server config — copy to .env and fill in ──
#   cp .env.example .env  &&  $EDITOR .env
# docker-compose reads this file (env_file: .env). NEVER commit the real .env.

# ── LLM provider (bring your own) ───────────────────────────────────────────
# Base URL of an OpenAI-compatible endpoint. Examples:
#   MiniMax     https://api.minimax.io/v1
#   OpenAI      https://api.openai.com/v1
#   OpenRouter  https://openrouter.ai/api/v1
#   DeepSeek    https://api.deepseek.com/v1
#   Groq        https://api.groq.com/openai/v1
# For a self-hosted LM Studio / Ollama on the SAME host as Docker, use
# http://172.17.0.1:1234/v1 (Linux docker0 gateway) — host.docker.internal
# only resolves on Docker Desktop (Mac/Windows), not a plain Linux server.
CASTOR_LLM_URL=https://api.minimax.io/v1
CASTOR_LLM_MODEL=MiniMax-M2.7
CASTOR_LLM_KEY=sk-your-provider-key-here

# ── Web UI auth — STRONGLY recommended when exposed on a server ─────────────
# Leave empty for no auth (only safe behind a private network / VPN).
CASTOR_PASSWORD=change-me-to-a-strong-password

# ── Optional: native Anthropic adapter (prompt caching + thinking budgets) ──
# Set provider to anthropic in the UI and supply a key to activate it.
# ANTHROPIC_API_KEY=sk-ant-...

# ── Advanced (sane defaults already set in the image) ───────────────────────
# CASTOR_DATA_DIR=/data          # persistent state mount (don't change)
# CASTOR_QDRANT_MODE=disk        # disk | memory | server
# CASTOR_EMBED_DEVICE=cpu        # cpu (default) | cuda (needs onnxruntime-gpu)
# CASTOR_ALLOW_PRIVATE_URLS=     # set 1 only for trusted internal KB scraping
